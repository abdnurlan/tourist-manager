# ─────────────────────────────────────────────────────────────
# Tur Planlayıcı — PRODUCTION environment (tour.m4strip.com)
#
# Bu fayl docker-compose.prod.yml tərəfindən oxunur (həm dəyişən
# əvəzləməsi, həm də backend konteynerinə ötürmə üçün).
#
# Serverdə istifadə:
#     cp .env.production.example .env
#     nano .env            # dəyərləri doldur
# Sonra: deploy/scripts/deploy.sh
#
# Bu .env faylı .gitignore-dadır — ƏSLA commit ETMƏ.
# Güclü secret yaratmaq üçün:  openssl rand -base64 48
# ─────────────────────────────────────────────────────────────

# --- Domain & TLS ---
# Tətbiqin işlədiyi tam subdomain.
DOMAIN=tour.m4strip.com
# Let's Encrypt bildirişləri üçün email (sertifikat bitmə xəbərdarlıqları).
ACME_EMAIL=developedbyamin@gmail.com

# --- Database (PostgreSQL) ---
POSTGRES_USER=tourapp
# GÜCLÜ parol qoy:  openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=tourist_manager
# Aşağıdakını ƏL ilə dəyişmə — yuxarıdakı 3 dəyərdən qurulur (compose substitution).
DATABASE_URL=postgres://tourapp:CHANGE_ME_strong_db_password@db:5432/tourist_manager?sslmode=disable

# --- Auth / JWT ---
# MÜTLƏQ uzun təsadüfi string:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_jwt_secret
# Admin hesabı (ilk boot-da bcrypt ilə bazaya yazılır).
ADMIN_USERNAME=admin
# GÜCLÜ admin parolu qoy.
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- CORS / API ---
# Yalnız production domeninə icazə (vergüllə ayrılmış siyahı dəstəklənir).
CORS_ORIGINS=https://tour.m4strip.com
# Brauzer bundle-na build zamanı yazılır — HTTPS domen + /api olmalıdır.
NEXT_PUBLIC_API_URL=https://tour.m4strip.com/api

# --- OpenAI (AI xidməti) ---
# Boş olsa AI zərif Azərbaycanca fallback qaytarır. Real açar əlavə et.
OPENAI_API_KEY=

# --- Telegram bot ---
# Production-da "webhook" (Telegram -> https://tour.m4strip.com/api/telegram/webhook).
TELEGRAM_MODE=webhook
# @BotFather token-i. Boş olsa bot işləmir.
TELEGRAM_BOT_TOKEN=
# YALNIZ sənin Telegram numeric user id-n icazəlidir (@userinfobot-dan al).
TELEGRAM_ALLOWED_USER_ID=
