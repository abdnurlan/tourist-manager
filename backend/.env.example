# ─────────────────────────────────────────────────────────────
# Tur Planlayıcı — Backend environment
# Copy this file to backend/.env and adjust the values:
#     cp backend/.env.example backend/.env
# The .env file is gitignored. docker-compose loads it via env_file.
# ─────────────────────────────────────────────────────────────

# --- Server ---
# Port the Fiber HTTP server listens on (inside the container and locally).
PORT=8080
# Comma-separated list of allowed CORS origins (frontend dev + docker + your domain).
# Add your production domain here too, e.g. https://tur.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database (PostgreSQL) ---
# Connection string. When running inside docker-compose the host is the
# compose service name "db" (compose also overrides this value at runtime).
# For local (non-docker) runs use "localhost".
#   docker:  postgres://postgres:postgres@db:5432/tourist_manager?sslmode=disable
#   local:   postgres://postgres:postgres@localhost:5432/tourist_manager?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@db:5432/tourist_manager?sslmode=disable

# --- Auth / JWT ---
# HS256 signing secret for JWTs. MUST be a long random string in production.
# Generate one:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-in-production
# Seed admin account (bcrypt-hashed into the users table on first boot).
# Fixed login for this product is admin / admin123 — change for production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- OpenAI (AI service — architecture/placeholder for MVP) ---
# If empty, the AI service returns a graceful Azerbaijani fallback
# ("AI hələ konfiqurasiya olunmayıb."). Set a real key to enable AI calls.
OPENAI_API_KEY=

# --- Telegram bot ---
# Mode: "webhook" (Telegram pushes updates to POST /api/telegram/webhook) or
#       "polling" (a backend goroutine long-polls getUpdates). Default: polling.
# Use "polling" for local development (no public URL needed). Use "webhook"
# in production behind HTTPS (see README "Telegram bot setup").
TELEGRAM_MODE=polling
# Bot token from @BotFather (e.g. 123456789:AAH...your-token...). Leave empty
# to run without the bot.
TELEGRAM_BOT_TOKEN=
# The ONLY Telegram numeric user id permitted to use the bot. Get it from
# @userinfobot or @RawDataBot. Every update from any other id is rejected.
TELEGRAM_ALLOWED_USER_ID=
