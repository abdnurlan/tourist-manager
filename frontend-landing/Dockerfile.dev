# ─────────────────────────────────────────────────────────────
# M4STrip — Landing (TanStack Start / Vite) DEV image (HMR / canlı yenilənmə)
# `vite dev` işə düşür; UI-da nəsə dəyişəndə brauzer avtomatik yenilənir.
# Mənbə kod compose-da bind-mount edilir — image içində kod SAXLANMIR.
# ─────────────────────────────────────────────────────────────
# TanStack Start node >=22 tələb edir.
FROM node:22-alpine
WORKDIR /app
RUN apk add --no-cache libc6-compat

# Asılılıqları əvvəlcədən quraşdır (kod bind-mount ilə gələcək).
# npm ci deyil — lock faylı köhnə ola bilər, npm install onu sinxronlaşdırır.
COPY package.json package-lock.json* ./
RUN npm install

EXPOSE 3001

# Bind-mount üzərində fayl dəyişikliyini tutmaq üçün polling lazımdır.
ENV CHOKIDAR_USEPOLLING=true

# Konteynerdən kənara açıq olsun deyə host 0.0.0.0, port 3001.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3001"]
