# ─────────────────────────────────────────────────────────────
# Tur Planlayıcı — Frontend environment
# Copy this file to frontend/.env and adjust the values:
#     cp frontend/.env.example frontend/.env
# The .env file is gitignored.
# ─────────────────────────────────────────────────────────────

# Public base URL of the backend API. MUST include the /api prefix and MUST be
# reachable FROM THE BROWSER (not from inside Docker). This value is baked into
# the client bundle at BUILD time (NEXT_PUBLIC_*), so set it before building.
#   local dev / docker on your machine:  http://localhost:8080/api
#   production (behind Nginx + SSL):      https://your-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Disable Next.js anonymous telemetry (optional).
NEXT_TELEMETRY_DISABLED=1
